{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    // Set strict to false to bypass 'implicit any' and property errors
    "strict": false,
    // Explicitly disable these for a smoother build
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "sourceMap": true
  },
  "include": [
    "src/**/*"
  ]
}